# คัดลอกไปใส่ Vercel: Project → Settings → Environment Variables
# (Local: สำเนาเป็น .env.local แล้วรีสตาร์ท `npm run dev`)
#
# ทุกค่าดึงจาก Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# ทางเลือก (server) — ถ้าไม่ตั้งบรรทัดบน แอปบันทึกจะใช้บรรทัดนี้แทน
# SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# บังคับสำหรับ API บันทึก (order intake / order items / …) — ห้ามใส่ prefix NEXT_PUBLIC_ (โหลดเฉพาะฝั่งเซิร์ฟเวอร์)
# ไม่ใส่จะ error ตอนเรียก API: Missing SUPABASE_SERVICE_ROLE_KEY … (ดู src/lib/supabase/service-role.ts)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ถ้าตารางไม่ชื่อ cars
# NEXT_PUBLIC_SUPABASE_CARS_TABLE=cars

# ไม่บังคับ — ใช้กำหนด metadataBase ตอน deploy (ถ้าไม่ใส่ Vercel จะใช้ VERCEL_URL ให้)
# NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
