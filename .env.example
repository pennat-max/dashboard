# คัดลอกไปใส่ Vercel: Project → Settings → Environment Variables
# (Local: สำเนาเป็น .env.local แล้วรีสตาร์ท `npm run dev`)
#
# ทุกค่าดึงจาก Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# ทางเลือก (server) — ถ้าไม่ตั้งบรรทัดบน แอปบันทึกจะใช้บรรทัดนี้แทน
# SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# --- Login (Supabase Auth) ---
# หน้า /dashboard เปิดสาธารณะ (เห็น KPI) — หน้าอื่นและ /dashboard/... ต้องล็อกอิน
# เปิด Authentication → Providers → Email — เปิด "Sign up" ถ้าต้องการให้ผู้ใช้สมัครเองจากหน้า /login
# Authentication → URL configuration:
#   Site URL: http://localhost:3000 (dev) หรือ https://your-app.vercel.app
#   Redirect URLs: เพิ่ม http://localhost:3000/auth/callback และ https://your-app.vercel.app/auth/callback

# บังคับสำหรับ API บันทึก (order intake / order items / …) และสร้างผู้ใช้จากระดับ 4 — ห้ามใส่ prefix NEXT_PUBLIC_
# ไม่ใส่จะ error ตอนเรียก API: Missing SUPABASE_SERVICE_ROLE_KEY … (ดู src/lib/supabase/service-role.ts)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ระดับผู้ใช้ (1–4) เก็บใน public.profiles — รัน migration ใน supabase/migrations/20260502120000_profiles_roles.sql ใน SQL Editor

# --- Order Tracking (/m, /liff): ค่าเริ่มต้นเปิดบันทึกได้โดยไม่ login — ตั้ง false เมื่อจะบังคับ session + role
# OPEN_ORDER_TRACKING_MUTATIONS=false

# --- LINE LIFF (Order Tracking in LINE app) — public, not a secret ---
# สร้าง LIFF app ใน LINE Developers แล้ววาง LIFF ID — ดู LINE_LIFF_SETUP.md
# เมื่อตั้งค่าแล้ว ปุ่มแชร์ LINE จะใช้ลิงก์ https://liff.line.me/<LIFF_ID>?order=… (เปิดใน LINE)
# ไม่ตั้ง → ใช้ลิงก์สั้น /m/o?o=… บนโดเมนแอปแทน
# NEXT_PUBLIC_LINE_LIFF_ID=1234567890-xxxxxxxx

# --- LINE Messaging API (webhook รับข้อความกลุ่ม/OA — server only) ---
# เปิด Messaging API ใน LINE Developers → channel → Messaging API → Channel secret / tokens
# Webhook URL: https://<your-domain>/api/line/webhook — ห้ามใส่ NEXT_PUBLIC_
# LINE_CHANNEL_SECRET=xxxxxxxx
# Channel access token (ตอบข้อความ / reply — ทำทีหลังได้)
# LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxx
# กลุ่มที่ยอมรับ: คั่นด้วยจุลภาค · Group ID ขึ้นต้นด้วย C — หาจาก log เมื่อเปิดบรรทัดล่างชั่วคราว แล้วส่งข้อความในกลุ่ม
# LINE_ALLOWED_GROUP_IDS=C1234...,C5678...
# เปิดชั่วคราวเพื่อให้ log พิมพ์ groupId (แล้วปิดเมื่อใส่ LINE_ALLOWED_GROUP_IDS แล้ว)
# LINE_WEBHOOK_LOG_GROUP_IDS=true
# รับแชท 1:1 กับ OA (ค่าเริ่มต้นปิด — เปิดเมื่อตั้งใจ)
# LINE_ACCEPT_DM=false
# LINE_ACCEPT_ROOM=false
# ถ้าตาราง inbox ไม่ชื่อ line_inbox_messages
# LINE_INBOX_MESSAGES_TABLE=line_inbox_messages

# ถ้าตารางไม่ชื่อ cars
# NEXT_PUBLIC_SUPABASE_CARS_TABLE=cars

# จำกัดจำนวนรถที่โหลดในหน้า Order Tracking (/m/orders, /liff/orders) เพื่อให้โหลดครั้งแรกเร็วขึ้น
# ค่าเริ่มต้นระบบตอนนี้ = ดึงทั้งหมด (ถ้าไม่ตั้ง)
# ถ้าต้องการดึงเฉพาะคันล่าสุดบางส่วน ให้ตั้งเป็นจำนวนคัน เช่น 120 / 180
# ORDER_TRACKING_MAX_CARS=180

# --- Order Tracking chip/count experiment (Preview only; default safe/off) ---
# false = ใช้พฤติกรรมเดิมของ /m/orders
# true = ทดลอง chip/count relationship + filtered card loading ทีละ 50
NEXT_PUBLIC_ORDER_CHIP_CACHE_ENABLED=false

# ไม่บังคับ — ใช้กำหนด metadataBase ตอน deploy (ถ้าไม่ใส่ Vercel จะใช้ VERCEL_URL ให้)
# NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# --- แปลชื่อ/หมายเหตุรายการ Order Tracking (บังคับถ้าต้องการแปล EN) ---
# ตั้งอย่างน้อยหนึ่งค่าบนเซิร์ฟเวอร์แล้ว restart หลังแก้ .env
# GROQ_API_KEY=gsk_...   https://console.groq.com/keys
# GEMINI_API_KEY=...     https://aistudio.google.com/apikey
# ไม่มีคีย์ = ปุ่มแปล/บันทึกจะไม่สร้าง label_en / note_en
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-2.5-flash

# บันทึกรายการ order_items: mobile ส่ง translate=false ต่อ save แล้ว (ไม่รอ AI — แปลด้วยปุ่ม Translate EN)
# ถ้ามี client อื่นส่ง translate:true ค่อยดู env นี้: false = ข้ามแปลแม้ขอ translate
# ORDER_ITEMS_TRANSLATE_ON_SAVE=false

# ไม่บังคับ — งานด่วน LINE ปุ่ม "ให้ AI ช่วย" ใช้ Google Gemini (เซิร์ฟเวอร์เท่านั้น ห้าม NEXT_PUBLIC_)
