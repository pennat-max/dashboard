# Supabase (Project Settings → API) — แอปใช้ anon key แบบไม่ล็อกอิน
# ต้องมี RLS policy ให้ role anon SELECT ตาราง cars (ดู supabase/schema.sql)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Optional: if your table name is not "cars"
# NEXT_PUBLIC_SUPABASE_CARS_TABLE=cars
